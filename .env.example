# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — it never goes to GitHub.
# For production, set the same variables in the Vercel dashboard:
# https://vercel.com/<your-username>/<your-project>/settings/environment-variables

# Google AI API key (Gemini 3.5 Flash + Nano Banana 2 image generation)
# Required. Workshop-provided keys available; pick one:
#   AIzaSyCFc927nJzWwqmGeDT_QmG6-kwIh6VWBAU
#   AIzaSyDRsCHcBP-difH7XVUdVpyKrU_EXpTzyRI
#   AIzaSyBYyLwg3oYgOT89oVpm2vl4NgVn9ac_pro
GOOGLE_AI_API_KEY=

# Replicate API token (Kling v2.x video generation)
# Optional. If missing, video generation is disabled — text + cover variants still work.
# Create at https://replicate.com → Settings → API Tokens → Create
# Requires billing topup (~$20 for testing 20-25 runs)
REPLICATE_API_TOKEN=
